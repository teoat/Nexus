        self.cache_ttl = 300  # 5 minutes
        
        # Start health monitoring
        self.start_health_monitoring()
    
    def start_health_monitoring(self):
        """Start background health monitoring"""
        def monitor_health():
            while True:
                try:
                    for service_name, service_config in self.services.items():
                        try:
                            response = requests.get(
                                f"{service_config['url']}{service_config['health_endpoint']}",
                                timeout=5
                            )
                            if response.status_code == 200:
                                service_config['status'] = 'healthy'
                            else:
                                service_config['status'] = 'unhealthy'
                        except Exception as e:
                            service_config['status'] = 'unhealthy'
                            logger.warning(f"⚠️ Service {service_name} is unhealthy: {e}")
                    
                    time.sleep(30)  # Check every 30 seconds
                    
                except Exception as e:
                    logger.error(f"❌ Health monitoring error: {e}")
                    time.sleep(60)
        
        health_thread = threading.Thread(target=monitor_health, daemon=True)
        health_thread.start()
        logger.info("🔄 Started health monitoring")
    
    def get_service_url(self, path):
        """Get the appropriate service URL for a given path"""
        for route, service_name in self.routes.items():
            if path.startswith(route):
                service_config = self.services.get(service_name)
                if service_config and service_config['status'] == 'healthy':
                    return f"{service_config['url']}{path}"
                else:
                    # Fallback to dashboard service
                    return f"{self.services['dashboard']['url']}{path}"
        
        # Default to dashboard service
        return f"{self.services['dashboard']['url']}{path}"
    
    def check_rate_limit(self, client_ip, endpoint):
        """Check if client has exceeded rate limit"""
        key = f"{client_ip}:{endpoint}"
        now = time.time()
        
        if key not in self.rate_limits:
            self.rate_limits[key] = []
        
        # Remove old entries (older than 1 minute)
        self.rate_limits[key] = [
            timestamp for timestamp in self.rate_limits[key]
            if now - timestamp < 60
        ]
        
        # Check if limit exceeded (100 requests per minute)
        if len(self.rate_limits[key]) >= 100:
            return False
        
        # Add current request
        self.rate_limits[key].append(now)
        return True
    
    def get_cached_response(self, path, params):
        """Get cached response if available"""
        cache_key = f"{path}:{hash(str(sorted(params.items())))}"
        
        if cache_key in self.cache:
            cached_data, timestamp = self.cache[cache_key]
            if time.time() - timestamp < self.cache_ttl:
                return cached_data
        
        return None
    
    def cache_response(self, path, params, response_data):
        """Cache response data"""
        cache_key = f"{path}:{hash(str(sorted(params.items())))}"
        self.cache[cache_key] = (response_data, time.time())
    
    def proxy_request(self, path, method='GET', data=None, params=None):
        """Proxy request to appropriate service"""
        try:
            service_url = self.get_service_url(path)
            
            # Check rate limit
            client_ip = request.remote_addr
            if not self.check_rate_limit(client_ip, path):
                return jsonify({
                    "success": False,
                    "error": "Rate limit exceeded"
                }), 429
            
            # Check cache for GET requests
            if method == 'GET' and params:
                cached_response = self.get_cached_response(path, params)
                if cached_response:
                    return jsonify(cached_response)
            
            # Make request to service
            if method == 'GET':
                response = requests.get(service_url, params=params, timeout=10)
            elif method == 'POST':
                response = requests.post(service_url, json=data, timeout=10)
            elif method == 'PUT':
                response = requests.put(service_url, json=data, timeout=10)
            elif method == 'DELETE':
                response = requests.delete(service_url, timeout=10)
            else:
                return jsonify({
                    "success": False,
                    "error": "Unsupported method"
                }), 405
            
            # Parse response
            response_data = response.json()
            
            # Cache successful GET responses
            if method == 'GET' and response.status_code == 200 and params:
                self.cache_response(path, params, response_data)
            
            return jsonify(response_data), response.status_code
            
        except requests.exceptions.Timeout:
            return jsonify({
                "success": False,
                "error": "Service timeout"
            }), 504
        except requests.exceptions.ConnectionError:
            return jsonify({
                "success": False,
                "error": "Service unavailable"
            }), 503
        except Exception as e:
            logger.error(f"❌ Proxy error: {e}")
            return jsonify({
                "success": False,
                "error": "Internal server error"
            }), 500

