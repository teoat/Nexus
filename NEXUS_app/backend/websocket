                return key
            except Exception as e:
                logger.warning(f"⚠️ Error loading key {key_name}: {e}")
        return None
    
    def start_key_rotation_monitoring(self):
        """Start a background task to monitor and rotate keys"""
        def monitor_and_rotate():
            while True:
                current_time = time.time()
                if current_time - self.last_key_rotation > self.key_rotation_interval:
                    logger.warning(f"⚠️ Key rotation interval reached. Rotating keys...")
                    self.rotate_keys()
                time.sleep(self.key_rotation_interval / 2) # Check half the interval
        
        rotation_thread = threading.Thread(target=monitor_and_rotate, daemon=True)
        rotation_thread.start()
        logger.info("🔑 Started key rotation monitoring")

