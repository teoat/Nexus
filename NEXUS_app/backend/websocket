    def __init__(self, project_root: str = "/Users/Arief/Desktop/Nexus"):
        self.project_root = Path(project_root)
        self.keys_dir = self.project_root / "encryption_keys"
        self.keys_dir.mkdir(exist_ok=True)
        
        # Encryption keys
        self.master_key = None
        self.data_key = None
        self.config_key = None
        
        # Encryption instances
        self.data_cipher = None
        self.config_cipher = None
        
        # Key rotation settings
        self.key_rotation_interval = 86400  # 24 hours
        self.last_key_rotation = 0
        
        # Initialize encryption
        self.initialize_encryption()
        
        # Start key rotation monitoring
        self.start_key_rotation_monitoring()
    
    def initialize_encryption(self):
        """Initialize encryption keys and ciphers"""
        try:
            # Load or generate master key
            self.master_key = self.load_or_generate_key("master.key")
            
            # Load or generate data encryption key
            self.data_key = self.load_or_generate_key("data.key")
            
            # Load or generate config encryption key
            self.config_key = self.load_or_generate_key("config.key")
            
            # Initialize ciphers
            self.data_cipher = Fernet(self.data_key)
            self.config_cipher = Fernet(self.config_key)
            
            logger.info("🔐 Encryption system initialized successfully")
            
        except Exception as e:
            logger.error(f"❌ Error initializing encryption: {e}")
            raise
    
    def load_or_generate_key(self, key_name: str) -> bytes:
        """Load existing key or generate new one"""
        key_file = self.keys_dir / key_name
        
        if key_file.exists():
            try:
                with open(key_file, 'rb') as f:
                    key = f.read()
                logger.info(f"🔑 Loaded existing key: {key_name}")
                return key
            except Exception as e:
                logger.warning(f"⚠️ Error loading key {key_name}: {e}")
        
        # Generate new key
        key = Fernet.generate_key()
        try:
            with open(key_file, 'wb') as f:
                f.write(key)
            os.chmod(key_file, 0o600)  # Restrict permissions
            logger.info(f" Generated new key: {key_name}")
            return key
        except Exception as e:
            logger.error(f"❌ Error saving key {key_name}: {e}")
            raise
    
    def encrypt_data(self, data: Union[str, bytes, dict], key_type: str = "data") -> str:
        """Encrypt data using specified key type"""
        try:
            # Convert data to bytes
            if isinstance(data, dict):
                data_bytes = json.dumps(data).encode('utf-8')
            elif isinstance(data, str):
                data_bytes = data.encode('utf-8')
            else:
                data_bytes = data
            
            # Select appropriate cipher
            if key_type == "data":
                cipher = self.data_cipher
            elif key_type == "config":
                cipher = self.config_cipher
            else:
                raise ValueError(f"Invalid key type: {key_type}")
            
            # Encrypt data
            encrypted_data = cipher.encrypt(data_bytes)
            
            # Encode as base64 for storage
            encoded_data = base64.b64encode(encrypted_data).decode('utf-8')
            
            logger.debug(f"🔐 Encrypted {len(data_bytes)} bytes using {key_type} key")
            return encoded_data
            
        except Exception as e:
            logger.error(f"❌ Error encrypting data: {e}")
            raise
    
    def decrypt_data(self, encrypted_data: str, key_type: str = "data") -> Union[str, dict]:
        """Decrypt data using specified key type"""
        try:
            # Decode from base64
            encrypted_bytes = base64.b64decode(encrypted_data.encode('utf-8'))
            
            # Select appropriate cipher
            if key_type == "data":
                cipher = self.data_cipher
            elif key_type == "config":
                cipher = self.config_cipher
            else:
                raise ValueError(f"Invalid key type: {key_type}")
            
            # Decrypt data
            decrypted_bytes = cipher.decrypt(encrypted_bytes)
            
            # Try to parse as JSON first, then as string
            try:
                decrypted_data = json.loads(decrypted_bytes.decode('utf-8'))
            except json.JSONDecodeError:
                decrypted_data = decrypted_bytes.decode('utf-8')
            
            logger.debug(f" Decrypted {len(decrypted_bytes)} bytes using {key_type} key")
            return decrypted_data
            
        except Exception as e:
            logger.error(f"❌ Error decrypting data: {e}")
            raise
    
    def encrypt_file(self, file_path: Union[str, Path], key_type: str = "data") -> str:
        """Encrypt entire file"""
        file_path = Path(file_path)
        
        if not file_path.exists():
            raise FileNotFoundError(f"File not found: {file_path}")
        
        try:
            with open(file_path, 'rb') as f:
                file_data = f.read()
            
            # Encrypt file data
            encrypted_data = self.encrypt_data(file_data, key_type)
            
            # Save encrypted data to a new file
            encrypted_file_path = file_path.parent / f"{file_path.stem}_encrypted{file_path.suffix}"
            with open(encrypted_file_path, 'wb') as f:
                f.write(encrypted_data.encode('utf-8')) # Save as UTF-8 string for base64
            
            logger.info(f"🔐 Encrypted file: {file_path} to {encrypted_file_path}")
            return encrypted_file_path
            
        except Exception as e:
            logger.error(f"❌ Error encrypting file {file_path}: {e}")
            raise
    
    def decrypt_file(self, encrypted_file_path: Union[str, Path], key_type: str = "data") -> Path:
        """Decrypt an encrypted file"""
        encrypted_file_path = Path(encrypted_file_path)
        
        if not encrypted_file_path.exists():
            raise FileNotFoundError(f"Encrypted file not found: {encrypted_file_path}")
        
        try:
            with open(encrypted_file_path, 'r', encoding='utf-8') as f:
                encrypted_data_str = f.read()
            
            # Decrypt file data
            decrypted_data = self.decrypt_data(encrypted_data_str, key_type)
            
            # Save decrypted data to a new file
            decrypted_file_path = encrypted_file_path.parent / f"{encrypted_file_path.stem}_decrypted{encrypted_file_path.suffix}"
            with open(decrypted_file_path, 'wb') as f:
                f.write(decrypted_data)
            
            logger.info(f" Decrypted file: {encrypted_file_path} to {decrypted_file_path}")
            return decrypted_file_path
            
        except Exception as e:
            logger.error(f"❌ Error decrypting file {encrypted_file_path}: {e}")
            raise
    
    def rotate_keys(self):
        """Rotate encryption keys"""
        try:
            # Generate new master key
            self.master_key = Fernet.generate_key()
            self.data_key = Fernet.generate_key()
            self.config_key = Fernet.generate_key()
            
            # Re-initialize ciphers with new keys
            self.data_cipher = Fernet(self.data_key)
            self.config_cipher = Fernet(self.config_key)
            
            # Save new keys
            self.save_key("master.key", self.master_key)
            self.save_key("data.key", self.data_key)
            self.save_key("config.key", self.config_key)
            
            logger.info("🔑 Keys rotated successfully")
            self.last_key_rotation = time.time()
            
        except Exception as e:
            logger.error(f"❌ Error rotating keys: {e}")
    
    def save_key(self, key_name: str, key_data: bytes):
        """Save a key to a file"""
        key_file = self.keys_dir / key_name
        try:
            with open(key_file, 'wb') as f:
                f.write(key_data)
            os.chmod(key_file, 0o600)
            logger.info(f"🔑 Saved key: {key_name}")
        except Exception as e:
            logger.error(f"❌ Error saving key {key_name}: {e}")
    
    def load_key(self, key_name: str) -> bytes:
        """Load a key from a file"""
