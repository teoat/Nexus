class NexusAPIGateway:
    """Centralized API Gateway for NEXUS Platform"""
    
    def __init__(self):
        self.services = {
            "dashboard": {
                "url": "http://localhost:8000",
                "health_endpoint": "/api/health",
                "status": "unknown"
            },
            "automation": {
