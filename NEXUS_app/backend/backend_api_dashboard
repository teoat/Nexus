    def load_sot_status(self):
        """Load SOT status from files"""
        try:
            # Load SOT files status
            sot_files = [
                "master_todo.md",
                "SINGLE_SOURCE_OF_TRUTH.json",
                "enhanced_automation_config.json",
                "unimplemented_tasks.json"
            ]
            
            for file_name in sot_files:
                file_path = self.project_root / file_name
                if file_path.exists():
                    self.sot_status["files"][file_name] = {
                        "exists": True,
                        "size": file_path.stat().st_size,
                        "modified": datetime.fromtimestamp(file_path.stat().st_mtime).isoformat(),
                        "status": "valid"
                    }
                else:
                    self.sot_status["files"][file_name] = {
                        "exists": False,
                        "status": "missing"
                    }
            
            self.sot_status["last_validation"] = datetime.now().isoformat()
            logger.info(f"📊 Loaded SOT status for {len(self.sot_status['files'])} files")
            
        except Exception as e:
            logger.error(f"❌ Error loading SOT status: {e}")
    
    def start_background_tasks(self):
        """Start background tasks for monitoring and updates"""
        def update_system_metrics():
            while True:
                try:
                    self.system_metrics.update({
                        "cpu_percent": psutil.cpu_percent(interval=1),
                        "memory_percent": psutil.virtual_memory().percent,
                        "disk_percent": psutil.disk_usage('/').percent,
                        "uptime": time.time() - psutil.boot_time(),
                        "response_time": time.time()
                    })
                    
                    # Emit metrics to connected clients
                    socketio.emit('system_metrics', self.system_metrics)
                    
                except Exception as e:
                    logger.error(f"❌ Error updating system metrics: {e}")
                
                time.sleep(5)  # Update every 5 seconds
        
        # Start background thread
        metrics_thread = threading.Thread(target=update_system_metrics, daemon=True)
        metrics_thread.start()
        logger.info("�� Started background system monitoring")
    
    def get_tasks(self, status_filter=None, priority_filter=None, search=None):
        """Get filtered tasks"""
        filtered_tasks = list(self.tasks.values())
        
        if status_filter:
            filtered_tasks = [t for t in filtered_tasks if t.status == status_filter]
        
        if priority_filter:
            filtered_tasks = [t for t in filtered_tasks if t.priority == priority_filter]
        
        if search:
            search_lower = search.lower()
            filtered_tasks = [t for t in filtered_tasks 
                            if search_lower in t.title.lower() or 
                               search_lower in t.description.lower()]
        
        return filtered_tasks
    
    def get_task_stats(self):
        """Get task statistics"""
        total_tasks = len(self.tasks)
        completed_tasks = len([t for t in self.tasks.values() if t.status == "done"])
        in_progress_tasks = len([t for t in self.tasks.values() if t.status == "in-progress"])
        pending_tasks = len([t for t in self.tasks.values() if t.status == "pending"])
        error_tasks = len([t for t in self.tasks.values() if t.status == "error"])
        
        completion_rate = (completed_tasks / total_tasks * 100) if total_tasks > 0 else 0
        
        return {
            "total_tasks": total_tasks,
            "completed_tasks": completed_tasks,
            "in_progress_tasks": in_progress_tasks,
            "pending_tasks": pending_tasks,
            "error_tasks": error_tasks,
            "completion_rate": round(completion_rate, 1)
        }
    
    def get_priority_breakdown(self):
        """Get priority breakdown"""
        breakdown = {"critical": 0, "high": 0, "medium": 0, "low": 0}
        
        for task in self.tasks.values():
            if task.priority in breakdown:
                breakdown[task.priority] += 1
        
        return breakdown
    
    def get_status_breakdown(self):
        """Get status breakdown"""
        breakdown = {"pending": 0, "in-progress": 0, "done": 0, "error": 0}
        
        for task in self.tasks.values():
            if task.status in breakdown:
                breakdown[task.status] += 1
        
        return breakdown

